{
  "name": "sdr-smart-hub-backend",
  "version": "1.0.0",
  "description": "Backend NestJS do SDR Smart Hub",
  "author": "GPressi",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
